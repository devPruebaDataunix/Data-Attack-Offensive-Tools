# Copia este fichero a bot/.env y rellénalo (bot/.env está ignorado por git).
# El auto-deploy.sh también lo crea preguntándote estos valores.

TELEGRAM_TOKEN=PON_AQUI_EL_TOKEN_DE_BOTFATHER
ALLOWED_USER_ID=PON_AQUI_TU_USER_ID
REPO_DIR=/ruta/absoluta/al/repo

# Opcional: fuerza un modelo para el Orquestador del bot (por defecto, el del proyecto).
# Ej.: claude-sonnet-4-6  ·  claude-opus-4-8
ORCH_MODEL=
