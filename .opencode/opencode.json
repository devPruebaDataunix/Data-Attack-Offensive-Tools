{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "orchestrator": {
      "mode": "primary",
      "model": "anthropic/claude-opus-4-8",
      "description": "Orquestador del engagement. Coordina los 18 especialistas (hub-and-spoke) y aplica el alcance. Ver AGENTS.md.",
      "temperature": 0.2,
      "permission": {
        "read": "allow",
        "edit": "allow",
        "bash": "ask",
        "webfetch": "allow",
        "websearch": "allow"
      }
    }
  },
  "permission": {
    "bash": "ask"
  },
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "llama3.1:8b": { "name": "Llama 3.1 8B (local)" },
        "qwen2.5-coder:7b": { "name": "Qwen2.5 Coder 7B (local)" }
      }
    }
  }
}
