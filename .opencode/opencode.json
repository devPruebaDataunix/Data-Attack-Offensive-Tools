{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "orchestrator": {
      "mode": "primary",
      "model": "anthropic/claude-opus-4-8",
      "description": "Orquestador del engagement. Coordina los 21 especialistas (hub-and-spoke) y aplica el alcance. Ver AGENTS.md.",
      "temperature": 0.2,
      "permission": {
        "read": "allow",
        "edit": "allow",
        "bash": "ask",
        "webfetch": "allow",
        "websearch": "allow"
      }
    }
  },
  "permission": {
    "bash": "ask"
  },
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": {
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "llama3.1:8b": { "name": "Llama 3.1 8B (local)" },
        "qwen2.5-coder:7b": { "name": "Qwen2.5 Coder 7B (local)" }
      }
    },
    "groq": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Groq (free · no entrena)",
      "options": {
        "baseURL": "https://api.groq.com/openai/v1",
        "apiKey": "{env:GROQ_API_KEY}"
      },
      "models": {
        "llama-3.3-70b-versatile": { "name": "Llama 3.3 70B Versatile (Groq)" },
        "llama-3.1-8b-instant": { "name": "Llama 3.1 8B Instant (Groq)" },
        "openai/gpt-oss-120b": { "name": "GPT-OSS 120B (Groq)" },
        "openai/gpt-oss-20b": { "name": "GPT-OSS 20B (Groq)" }
      }
    },
    "cerebras": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Cerebras (free · no entrena)",
      "options": {
        "baseURL": "https://api.cerebras.ai/v1",
        "apiKey": "{env:CEREBRAS_API_KEY}"
      },
      "models": {
        "gpt-oss-120b": { "name": "GPT-OSS 120B (Cerebras)" },
        "qwen-3-32b": { "name": "Qwen 3 32B (Cerebras)" },
        "zai-glm-4.7": { "name": "GLM 4.7 (Cerebras)" },
        "llama3.1-8b": { "name": "Llama 3.1 8B (Cerebras)" }
      }
    },
    "deepseek": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "DeepSeek (LAB-ONLY · entrena/residencia sensible)",
      "options": {
        "baseURL": "https://api.deepseek.com",
        "apiKey": "{env:DEEPSEEK_API_KEY}"
      },
      "models": {
        "deepseek-v4-flash": { "name": "DeepSeek V4 Flash" },
        "deepseek-v4-pro": { "name": "DeepSeek V4 Pro" }
      }
    },
    "minimax": {
      "npm": "@ai-sdk/anthropic",
      "name": "MiniMax (LAB-ONLY · Anthropic-compatible · entrena/residencia)",
      "options": {
        "baseURL": "https://api.minimax.io/anthropic/v1",
        "apiKey": "{env:MINIMAX_API_KEY}"
      },
      "models": {
        "MiniMax-M2.7": { "name": "MiniMax M2.7" },
        "MiniMax-M3": { "name": "MiniMax M3" }
      }
    },
    "zhipu": {
      "npm": "@ai-sdk/anthropic",
      "name": "Zhipu GLM (LAB-ONLY · Anthropic-compatible · entrena/residencia)",
      "options": {
        "baseURL": "https://api.z.ai/api/anthropic",
        "apiKey": "{env:ZHIPU_API_KEY}"
      },
      "models": {
        "glm-4.6": { "name": "GLM 4.6" },
        "glm-4.7": { "name": "GLM 4.7" }
      }
    },
    "openrouter": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "OpenRouter (LAB-ONLY · los :free entrenan/residencia)",
      "options": {
        "baseURL": "https://openrouter.ai/api/v1",
        "apiKey": "{env:OPENROUTER_API_KEY}"
      },
      "models": {
        "deepseek/deepseek-chat-v3-0324:free": { "name": "DeepSeek V3 0324 (free)" },
        "meta-llama/llama-3.3-70b-instruct:free": { "name": "Llama 3.3 70B Instruct (free)" },
        "qwen/qwen3-235b-a22b:free": { "name": "Qwen3 235B A22B (free)" }
      }
    },
    "nvidia": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "NVIDIA NIM (free · no entrena s/ ToS · LAB-ONLY · 100+ modelos)",
      "options": {
        "baseURL": "https://integrate.api.nvidia.com/v1",
        "apiKey": "{env:NVIDIA_API_KEY}"
      },
      "models": {
        "deepseek-ai/deepseek-r1": { "name": "DeepSeek R1 (NVIDIA · razonamiento)" },
        "nvidia/llama-3.3-nemotron-super-49b-v1": { "name": "Llama 3.3 Nemotron Super 49B (NVIDIA · razonamiento)" },
        "meta/llama-3.3-70b-instruct": { "name": "Llama 3.3 70B Instruct (NVIDIA)" },
        "openai/gpt-oss-120b": { "name": "GPT-OSS 120B (NVIDIA)" }
      }
    }
  }
}
