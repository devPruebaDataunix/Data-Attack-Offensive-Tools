# Claves de los providers FREE del espejo opencode (LAB-ONLY).
# opencode las lee en runtime vía {env:VAR} de opencode.json — NO requiere 'opencode auth login'.
# Uso:  cp opencode.example.env opencode.env  &&  edita  &&  set -a; . ./opencode.env; set +a
# (opencode.env y cualquier *.env están gitignored; esta plantilla *.example.env sí se versiona.)
#
# REGLAS DURAS: estas claves son para LABORATORIOS PROPIOS. Jamás se enruta un agente a un modelo
# free con datos de cliente, ni en E2/E3. El bot real de engagements no usa nada de esto (100% Anthropic).

# ── No entrenan con los prompts (perfil ACTIVO por defecto en routing.json) ──
GROQ_API_KEY=
CEREBRAS_API_KEY=

# ── Opt-in manual: declarados en opencode.json pero NO enrutados. Entrenan/residencia sensible →
#    solo lab puro. Para usarlos, añade su 'provider/model' a tools/routing.json y exporta la clave. ──
DEEPSEEK_API_KEY=
MINIMAX_API_KEY=
ZHIPU_API_KEY=
OPENROUTER_API_KEY=
