# ─── Generado en runtime ───────────────────────────────────────
.claude/audit/
# Memoria de aprendizaje por agente. La `local` es per-operador y NUNCA se versiona (datos que
# podrían filtrar entre clientes). La `project` (.claude/agent-memory/) SÍ se comparte por git a
# propósito, pero el hook memory_guard.py la sanea para que solo contenga técnica generalizada.
.claude/agent-memory-local/
rag/vulns.db
rag/vulns.db-*
rag/knowledge/kb.db
rag/knowledge/kb.db-*
rag/knowledge/kb_vec.db
rag/knowledge/kb_vec.db-*
rag/knowledge/.cache/
rag/.refresh.log
benchmark/results.jsonl
report/INFORME-*.md
report/findings-summary.csv
# Backup del routing activo que deja apply_routing.py al montar un perfil alternativo (NVIDIA-lab).
tools/routing.json.bak

# ─── Python / venv ─────────────────────────────────────────────
**/__pycache__/
*.pyc
.venv/
bot/.venv/

# ─── Editor / OS / logs ────────────────────────────────────────
.vscode/
.DS_Store
*.log
deploy/*.log

# Cache local del council de revisión (no versionar: notas de revisión efímeras)
.claude/council-cache/

# SkillOpt (skilltrain): salida y config locales (build-time, LAB-only) — no versionar
skilltrain/out/
skilltrain/config.json
skilltrain/**/__pycache__/
