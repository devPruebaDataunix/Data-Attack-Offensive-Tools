{
  "$comment": "Config de Claude Code para la suite Cyberseg Agents. El hook scope_guard es la barrera dura de alcance.",
  "$comment_modelos": "Sin CLAUDE_CODE_SUBAGENT_MODEL a propósito: cada agente usa su propio 'model' (tier de coste, v1.4.0: 4 opus-4-8 / 8 sonnet / 6 haiku, sin fable). opus-4-8 SOLO en web-exploit, post-exploit, ai-security y reporting (donde rompe la box / calidad del informe); sonnet en tool-drivers con juicio; haiku en recon/parseo mecánico (sin 'effort': Haiku da 400). El Orquestador (bot, ORCH_MODEL) corre opus-4-8 a effort 'medium' (ORCH_EFFORT) con techo USD opcional (ORCH_MAX_USD).",
  "permissions": {
    "defaultMode": "default",
    "ask": [
      "Bash(nmap:*)",
      "Bash(nuclei:*)",
      "Bash(sqlmap:*)",
      "Bash(metasploit:*)",
      "Bash(msfconsole:*)",
      "Bash(hydra:*)",
      "Bash(curl:*)",
      "Bash(ffuf:*)"
    ],
    "deny": [
      "Bash(rm -rf /*)",
      "Write(./contracts/scope.json)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/scope_guard.py"
          },
          {
            "type": "command",
            "command": "python .claude/hooks/budget_guard.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit|NotebookEdit|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python tools/gen_arch_diagram.py --hook"
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/validate_blackboard.py"
          },
          {
            "type": "command",
            "command": "python .claude/hooks/secret_scan.py"
          },
          {
            "type": "command",
            "command": "python .claude/hooks/a2a_guard.py"
          }
        ]
      },
      {
        "matcher": "Task",
        "hooks": [
          {
            "type": "command",
            "command": "python .claude/hooks/a2a_router_nudge.py"
          }
        ]
      }
    ]
  }
}
